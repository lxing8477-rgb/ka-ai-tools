const { GoogleGenerativeAI } = require("@google/generative-ai");

module.exports = async (req, res) => {
  // 设置返回内容为 HTML 格式，支持中文显示
  res.setHeader('Content-Type', 'text/html; charset=utf-8');

  const apiKey = process.env.GEMINI_API_KEY;
  if (!apiKey) {
    return res.status(500).send("<h1>AI 还在打瞌睡</h1><p>请在 Vercel 设置中检查 GEMINI_API_KEY</p>");
  }

  const genAI = new GoogleGenerativeAI(apiKey);
  const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });

  // 获取用户输入的话题
  const protocol = req.headers['x-forwarded-proto'] || 'http';
  const fullUrl = `${protocol}://${req.headers.host}${req.url}`;
  const { searchParams } = new URL(fullUrl);
  const topic = searchParams.get('topic') || "生活";

  const prompt = `你是一个推文专家。请根据话题 "${topic}" 写一段有深度、有哲学感的推文，要求语言精炼。`;

  try {
    const result = await model.generateContent(prompt);
    const response = await result.response;
    const text = response.text();
    
    // 返回精美的显示结果
    res.status(200).send(`
      <div style="padding: 20px; font-family: sans-serif;">
        <h2>✨ 你的 AI 推文生成好了：</h2>
        <p style="font-size: 1.2em; line-height: 1.6; color: #333;">${text}</p>
        <hr>
        <p><a href="/api/index?topic=哲学">尝试另一个话题</a></p>
      </div>
    `);
  } catch (error) {
    res.status(500).send(`<h1>生成失败</h1><p>${error.message}</p>`);
  }
};


